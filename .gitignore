cat > .gitignore << 'EOF'
# Dependency Folders (covers root and subfolders)
node_modules/
**/node_modules/

# Environment Variables
.env
.env.local
.env.*.local
**/.env
**/.env.local

# Build & Dist Artifacts
dist/
build/
**/dist/
**/build/

# Logs & Debugs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / IDE Cache
.DS_Store
Thumbs.db
.vscode/
.idea/

# Vite Cache
.vite/
**/.vite/
EOF